{
  "name": "drive-pass",
  "version": "2.0.0",
  "description": "Ứng dụng học lý thuyết lái xe (backend Node.js + frontend React)",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build",
    "start": "npm --workspace backend run start",
    "db:setup": "npm --workspace backend run db:setup",
    "db:import": "npm --workspace backend run db:import",
    "db:test": "npm --workspace backend run db:test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
